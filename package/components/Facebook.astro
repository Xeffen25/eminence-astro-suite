---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/facebook}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/facebook.mdx}
 * ---
 * @summary Renders Facebook Open Graph admin metadata tags.
 * @description
 * Outputs either a single `fb:app_id` meta tag or one or more `fb:admins`
 * meta tags depending on which prop shape is provided.
 *
 * @example
 * <Facebook appId="123456789" />
 * @example
 * <Facebook admins={["10001", "10002"]} />
 *
 * @see {@link https://developers.facebook.com/docs/sharing/webmasters#markup Facebook Sharing metadata reference}
 */
type WithAppId = {
	appId: string;
	admins?: never;
};

type WithAdmins = {
	admins: string | string[];
	appId?: never;
};

type Props = WithAppId | WithAdmins;

const { appId, admins } = Astro.props;
---

{appId && <meta property="fb:app_id" content={appId} />}
{admins && (Array.isArray(admins) ? admins : [admins]).map((id) => <meta property="fb:admins" content={id} />)}
