---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/head}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/head.mdx}
 * ---
 * @summary The ultimate `<head>` component for your Astro project.
 * @description
 * Renders a `<head>` element with built-in support for common SEO and metadata tags. Following Capo.js convention as much as possible, allows you to configure site wide defaults via the `head` property in your integration options, and override them on a per-page basis by passing props to the component. With best practices baked in as defaults, you can focus on customizing the essentials and let the component handle the rest.
 *
 * @example
 * <Head head={{ title: "Home" }} />
 * @example
 * <Head head={{ title: "Home", titleTemplate: "%s | My Site", charset: "iso-8859-1" }} />
 *
 * @see {@link https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/head MDN head element reference}
 */

import type { ComponentProps } from "astro/types";
import clientHeadConfig from "virtual:eminence-astro-seo/config";

import Alternate from "./Alternate.astro";
import AppleWebApp from "./AppleWebApp.astro";
import AppLinks from "./AppLinks.astro";
import ApplicationName from "./ApplicationName.astro";
import Archives from "./Archives.astro";
import Assets from "./Assets.astro";
import Author from "./Author.astro";
import Base from "./Base.astro";
import Bookmarks from "./Bookmarks.astro";
import Canonical from "./Canonical.astro";
import Charset from "./Charset.astro";
import ColorScheme from "./ColorScheme.astro";
import Creator from "./Creator.astro";
import Description from "./Description.astro";
import Facebook from "./Facebook.astro";
import Generator from "./Generator.astro";
import HumansTxt from "./HumansTxt.astro";
import Manifest from "./Manifest.astro";
import OpenGraph from "./OpenGraph.astro";
import Pinterest from "./Pinterest.astro";
import Publisher from "./Publisher.astro";
import Robots from "./Robots.astro";
import ThemeColor from "./ThemeColor.astro";
import Title from "./Title.astro";
import Verification from "./Verification.astro";
import Viewport from "./Viewport.astro";

import { toOptionalHrefProps } from "../utils";

interface Props {
	charset?: ComponentProps<typeof Charset>["charset"];
	viewport?: ComponentProps<typeof Viewport>["content"];
	base?: ComponentProps<typeof Base>;
	title: ComponentProps<typeof Title>["value"];
	titleTemplate?: ComponentProps<typeof Title>["template"];
	alternates?: ComponentProps<typeof Alternate>;
	appleWebApp?: ComponentProps<typeof AppleWebApp>;
	appLinks?: ComponentProps<typeof AppLinks>;
	applicationName?: ComponentProps<typeof ApplicationName>["content"];
	archives?: ComponentProps<typeof Archives>["hrefs"];
	assets?: ComponentProps<typeof Assets>["hrefs"];
	author?: ComponentProps<typeof Author>["content"];
	bookmarks?: ComponentProps<typeof Bookmarks>["hrefs"];
	canonical?: ComponentProps<typeof Canonical>["href"] | boolean;
	colorScheme?: ComponentProps<typeof ColorScheme>["content"];
	creator?: ComponentProps<typeof Creator>["content"];
	description?: ComponentProps<typeof Description>["content"];
	facebook?: ComponentProps<typeof Facebook>;
	generator?: ComponentProps<typeof Generator>["generate"];
	humansTxt?: ComponentProps<typeof HumansTxt>["href"] | boolean;
	manifest?: ComponentProps<typeof Manifest>["href"] | boolean;
	openGraph?: ComponentProps<typeof OpenGraph>;
	pinterest?: ComponentProps<typeof Pinterest>;
	publisher?: ComponentProps<typeof Publisher>["content"];
	robots?: ComponentProps<typeof Robots>;
	themeColor?: ComponentProps<typeof ThemeColor>;
	verification?: ComponentProps<typeof Verification>;
}

const {
	charset = clientHeadConfig.charset,
	viewport = clientHeadConfig.viewport,
	base = clientHeadConfig.base,
	title,
	titleTemplate = clientHeadConfig.titleTemplate,
	alternates,
	appleWebApp = clientHeadConfig.appleWebApp,
	appLinks,
	applicationName = clientHeadConfig.applicationName,
	archives,
	assets,
	author = clientHeadConfig.author,
	bookmarks,
	canonical: propCanonical,
	colorScheme = clientHeadConfig.colorScheme,
	creator = clientHeadConfig.creator,
	description,
	facebook = clientHeadConfig.facebook,
	generator = clientHeadConfig.generator,
	humansTxt = clientHeadConfig.humansTxt,
	manifest,
	openGraph,
	pinterest = clientHeadConfig.pinterest,
	publisher = clientHeadConfig.publisher,
	robots = clientHeadConfig.robots,
	themeColor = clientHeadConfig.themeColor,
	verification = clientHeadConfig.verification,
} = Astro.props;

const canonical = toOptionalHrefProps<ComponentProps<typeof Canonical>>(propCanonical);
const humansTxtProps = toOptionalHrefProps<ComponentProps<typeof HumansTxt>>(humansTxt);
const manifestProps = toOptionalHrefProps<ComponentProps<typeof Manifest>>(manifest);
---

<head>
	<Charset charset={charset} />
	<Viewport content={viewport} />

	{base && <Base {...base} />}
	<Title value={title} template={titleTemplate} />
	<slot />
	{alternates && <Alternate {...alternates} />}
	{appleWebApp && <AppleWebApp {...appleWebApp} />}
	{appLinks && <AppLinks {...appLinks} />}
	{applicationName && <ApplicationName content={applicationName} />}
	{archives && <Archives hrefs={archives} />}
	{assets && <Assets hrefs={assets} />}
	{author && <Author content={author} />}
	{bookmarks && <Bookmarks hrefs={bookmarks} />}
	{canonical && <Canonical {...canonical} />}
	{colorScheme && <ColorScheme content={colorScheme} />}
	{creator && <Creator content={creator} />}
	{description && <Description content={description} />}
	{facebook && <Facebook {...facebook} />}
	{generator !== undefined && <Generator generate={generator} />}
	{humansTxtProps && <HumansTxt {...humansTxtProps} />}
	{manifestProps && <Manifest {...manifestProps} />}
	{openGraph && <OpenGraph {...openGraph} />}
	{pinterest && <Pinterest {...pinterest} />}
	{publisher && <Publisher content={publisher} />}
	{robots && <Robots {...robots} />}
	{themeColor && <ThemeColor {...themeColor} />}
	{verification && <Verification {...verification} />}
</head>
