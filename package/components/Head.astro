---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/head}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/head.mdx}
 * ---
 * @summary The ultimate `<head>` component for your Astro project.
 * @description
 * Renders a `<head>` element with built-in support for common SEO and metadata tags. Following Capo.js convention as much as possible, allows you to configure site wide defaults via the `head` property in your integration options, and override them on a per-page basis by passing props to the component. With best practices baked in as defaults, you can focus on customizing the essentials and let the component handle the rest.
 *
 * @example
 * <Head head={{ title: "Home" }} />
 * @example
 * <Head head={{ title: "Home", titleTemplate: "%s | My Site", charset: "iso-8859-1" }} />
 *
 * @see {@link https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/head MDN head element reference}
 */

import type { ComponentProps } from "astro/types";

import LanguageAlternates from "./LanguageAlternates.astro";
import AppleItunesApp from "./AppleItunesApp.astro";
import AppLinks from "./AppLinks.astro";
import Base from "./Base.astro";
import Canonical from "./Canonical.astro";
import Charset from "./Charset.astro";
import ColorScheme from "./ColorScheme.astro";
import Description from "./Description.astro";
import Generator from "./Generator.astro";
import HumansTxt from "./HumansTxt.astro";
import Icons from "./Icons.astro";
import JsonLd from "./JsonLd.astro";
import Manifest from "./Manifest.astro";
import OpenGraph from "./OpenGraph.astro";
import Robots from "./Robots.astro";
import ThemeColor from "./ThemeColor.astro";
import Title from "./Title.astro";
import Verification from "./Verification.astro";
import Viewport from "./Viewport.astro";

interface Props {
	charset?: ComponentProps<typeof Charset>["charset"] | false;
	viewport?: ComponentProps<typeof Viewport>["content"] | false;
	base?: ComponentProps<typeof Base> | false;
	title: ComponentProps<typeof Title>["value"];
	titleTemplate?: ComponentProps<typeof Title>["template"];
	appleItunesApp?: ComponentProps<typeof AppleItunesApp> | false;
	appLinks?: ComponentProps<typeof AppLinks> | false;
	canonical?: ComponentProps<typeof Canonical>["href"] | false;
	colorScheme?: ComponentProps<typeof ColorScheme>["content"] | false;
	description?: ComponentProps<typeof Description>["content"];
	generator?: ComponentProps<typeof Generator>["generate"];
	humansTxt?: ComponentProps<typeof HumansTxt>["href"] | false;
	icons?: ComponentProps<typeof Icons> | false;
	jsonLd?: ComponentProps<typeof JsonLd>["jsonLd"];
	languageAlternates?: ComponentProps<typeof LanguageAlternates>["languages"];
	manifest?: ComponentProps<typeof Manifest>["href"] | false;
	openGraph?: ComponentProps<typeof OpenGraph>;
	robots?: ComponentProps<typeof Robots>;
	themeColor?: ComponentProps<typeof ThemeColor> | false;
	verification?: ComponentProps<typeof Verification> | false;
}

const {
	charset,
	viewport,
	base,
	title,
	titleTemplate,
	appleItunesApp,
	appLinks,
	canonical,
	colorScheme,
	description,
	generator,
	humansTxt,
	icons,
	jsonLd,
	languageAlternates,
	manifest,
	openGraph,
	robots,
	themeColor,
	verification,
} = Astro.props;
---

<head>
	{charset !== false && <Charset charset={charset} />}
	{viewport !== false && <Viewport content={viewport} />}
	{base !== false && <Base {...(base ?? {})} />}
	<Title value={title} template={titleTemplate} />
	<slot />
	{appleItunesApp !== false && <AppleItunesApp {...(appleItunesApp ?? {})} />}
	{appLinks !== false && <AppLinks {...(appLinks ?? {})} />}
	{canonical !== false && <Canonical href={canonical} />}
	{colorScheme !== false && <ColorScheme content={colorScheme} />}
	{description && <Description content={description} />}
	{generator !== false && <Generator generate={generator} />}
	{humansTxt !== false && <HumansTxt href={humansTxt} />}
	{icons !== false && <Icons {...(icons ?? {})} />}
	{jsonLd && <JsonLd jsonLd={jsonLd} />}
	{languageAlternates && <LanguageAlternates languages={languageAlternates} />}
	{manifest !== false && <Manifest href={manifest} />}
	{openGraph && <OpenGraph {...openGraph} />}
	<Robots {...robots ?? {}} />
	{themeColor !== false && <ThemeColor {...themeColor} />}
	{verification !== false && <Verification {...verification} />}
</head>
