---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/base}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/base.mdx}
 * ---
 * @summary Renders a `<base>` tag for relative URL resolution.
 * @description
 * Outputs a `<base>` tag when either or both `href` or `target` are provided.
 *
 * @example
 * <Base href="https://example.com" />
 * @example
 * <Base href="https://example.com" target="_blank" />
 *
 * @see {@link https://developer.mozilla.org/es/docs/Web/HTML/Reference/Elements/base MDN base element reference}
 */

interface Props {
	/**
	 * Base URL used for all relative URLs in the document.
	 */
	href?: string;
	/**
	 * Default browsing context for links and forms.
	 */
	target?: string;
}

const { href, target } = Astro.props;
---

{(href !== undefined || target !== undefined) && <base href={href} target={target} />}
