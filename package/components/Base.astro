---
import clientHeadConfig from "virtual:eminence-astro-suite/config";

import { hasAnyProp } from "../utils";

interface Props {
	/**
	 * Base URL used for all relative URLs in the document.
	 */
	href?: string;
	/**
	 * Default browsing context for links and forms.
	 */
	target?: string;
}

const { href, target } = (hasAnyProp(Astro.props) ? Astro.props : (clientHeadConfig.base ?? {})) as Props;
---

{(href !== undefined || target !== undefined) && <base href={href} target={target} />}
