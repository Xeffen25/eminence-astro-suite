---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/open-graph-music}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/open-graph-music.mdx}
 * ---
 * @summary Renders Open Graph music namespace meta tags.
 * @description
 * Outputs `music:*` meta tags for music pages. The `subtype` determines
 * `og:type` in the parent: `music.song`, `music.album`, `music.playlist`, or
 * `music.radio_station`. Each subtype supports a relevant subset of music
 * metadata fields. Inferred automatically when a `music` object is passed to
 * the parent `OpenGraph` component.
 *
 * @example
 * <OpenGraphMusic subtype="song" duration={214} musician="https://example.com/artist" />
 * @example
 * <OpenGraphMusic subtype="album" musician={["https://example.com/artist"]} releaseDate="2026-01-01" />
 *
 * @see {@link https://ogp.me/#type_music Open Graph music type}
 */

interface Props {
	subtype: "song" | "album" | "playlist" | "radio_station";
	duration?: number;
	album?: string;
	albumDisc?: number;
	albumTrack?: number;
	song?: string | string[];
	songDisc?: number;
	songTrack?: number;
	musician?: string | string[];
	releaseDate?: string;
	creator?: string;
}

const { subtype, duration, album, albumDisc, albumTrack, songDisc, songTrack, releaseDate, creator } = Astro.props;
const musicians = Astro.props.musician
	? Array.isArray(Astro.props.musician)
		? Astro.props.musician
		: [Astro.props.musician]
	: [];
const songs = Astro.props.song ? (Array.isArray(Astro.props.song) ? Astro.props.song : [Astro.props.song]) : [];
---

{duration !== undefined && <meta property="music:duration" content={String(duration)} />}
{album && <meta property="music:album" content={album} />}
{albumDisc !== undefined && <meta property="music:album:disc" content={String(albumDisc)} />}
{albumTrack !== undefined && <meta property="music:album:track" content={String(albumTrack)} />}
{songs.map((s) => <meta property="music:song" content={s} />)}
{songDisc !== undefined && <meta property="music:song:disc" content={String(songDisc)} />}
{songTrack !== undefined && <meta property="music:song:track" content={String(songTrack)} />}
{musicians.map((m) => <meta property="music:musician" content={m} />)}
{releaseDate && <meta property="music:release_date" content={releaseDate} />}
{
	(subtype === "playlist" || subtype === "radio_station") && creator && (
		<meta property="music:creator" content={creator} />
	)
}
