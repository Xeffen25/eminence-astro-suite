---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/open-graph-article}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/open-graph-article.mdx}
 * ---
 * @summary Renders Open Graph article namespace meta tags.
 * @description
 * Outputs `article:*` meta tags for pages of type `og:type="article"`. Inferred
 * automatically when an `article` object is passed to the parent `OpenGraph`
 * component. Supports published time, modification time, expiration time, one or
 * more author profile URLs, a section label, and one or more tags.
 *
 * @example
 * <OpenGraphArticle publishedTime="2026-01-01T00:00:00Z" authors={["https://example.com/author"]} />
 * @example
 * <OpenGraphArticle section="Technology" tags={["astro", "seo"]} />
 *
 * @see {@link https://ogp.me/#type_article Open Graph article type}
 */

interface Props {
	publishedTime?: string;
	modifiedTime?: string;
	expirationTime?: string;
	authors?: string | string[];
	section?: string;
	tags?: string | string[];
}

const { publishedTime, modifiedTime, expirationTime, section } = Astro.props;
const authors = Astro.props.authors
	? Array.isArray(Astro.props.authors)
		? Astro.props.authors
		: [Astro.props.authors]
	: [];
const tags = Astro.props.tags ? (Array.isArray(Astro.props.tags) ? Astro.props.tags : [Astro.props.tags]) : [];
---

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{expirationTime && <meta property="article:expiration_time" content={expirationTime} />}
{authors.map((a) => <meta property="article:author" content={a} />)}
{section && <meta property="article:section" content={section} />}
{tags.map((t) => <meta property="article:tag" content={t} />)}
