---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/open-graph-video}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/open-graph-video.mdx}
 * ---
 * @summary Renders Open Graph video media and type-specific meta tags.
 * @description
 * Handles two related roles for the `video` object. When `src` is provided,
 * it outputs `og:video` structured property tags for embedding a video in
 * social previews. When `subtype` is provided, it outputs `video:*` namespace
 * tags used by crawlers for rich video page metadata. Both roles may coexist.
 * The MIME type for `og:video:type` is inferred from the file extension when
 * not explicitly provided.
 *
 * @example
 * <OpenGraphVideo src="https://example.com/video.mp4" width={1280} height={720} />
 * @example
 * <OpenGraphVideo subtype="movie" director="https://example.com/director" duration={6900} />
 *
 * @see {@link https://ogp.me/#type_video Open Graph video type}
 * @see {@link https://ogp.me/#structured Open Graph structured properties}
 */

import { toHref } from "../../utils";

const VIDEO_MIME_MAP: Record<string, string> = {
	mp4: "video/mp4",
	webm: "video/webm",
	ogg: "video/ogg",
	m4v: "video/mp4",
	mov: "video/quicktime",
	avi: "video/x-msvideo",
};

function inferVideoMimeType(src: string): string | undefined {
	const key = src.split(".").pop()?.split("?")[0]?.toLowerCase() ?? "";
	return VIDEO_MIME_MAP[key];
}

interface Props {
	src?: StringOrURL;
	secureUrl?: StringOrURL;
	type?: string;
	width?: number;
	height?: number;
	subtype?: "movie" | "episode" | "tv_show" | "other";
	actor?: string | string[];
	director?: string | string[];
	writer?: string | string[];
	duration?: number;
	releaseDate?: string;
	tag?: string | string[];
	series?: string;
}

const { src, secureUrl, type, subtype, actor, director, writer, duration, releaseDate, tag, series } = Astro.props;

const resolvedSrc = src ? toHref(src) : undefined;
const resolvedType = resolvedSrc ? (type ?? inferVideoMimeType(resolvedSrc)) : undefined;
const resolvedSecureUrl = secureUrl ? toHref(secureUrl) : undefined;
const resolvedWidth = Astro.props.width;
const resolvedHeight = Astro.props.height;

const actors = actor ? (Array.isArray(actor) ? actor : [actor]) : [];
const directors = director ? (Array.isArray(director) ? director : [director]) : [];
const writers = writer ? (Array.isArray(writer) ? writer : [writer]) : [];
const tags = tag ? (Array.isArray(tag) ? tag : [tag]) : [];
---

{resolvedSrc && <meta property="og:video" content={resolvedSrc} />}
{resolvedSrc && resolvedSecureUrl && <meta property="og:video:secure_url" content={resolvedSecureUrl} />}
{resolvedSrc && resolvedType && <meta property="og:video:type" content={resolvedType} />}
{resolvedSrc && resolvedWidth !== undefined && <meta property="og:video:width" content={String(resolvedWidth)} />}
{resolvedSrc && resolvedHeight !== undefined && <meta property="og:video:height" content={String(resolvedHeight)} />}
{subtype && actors.map((a) => <meta property="video:actor" content={a} />)}
{subtype && directors.map((d) => <meta property="video:director" content={d} />)}
{subtype && writers.map((w) => <meta property="video:writer" content={w} />)}
{subtype && duration !== undefined && <meta property="video:duration" content={String(duration)} />}
{subtype && releaseDate && <meta property="video:release_date" content={releaseDate} />}
{subtype && tags.map((t) => <meta property="video:tag" content={t} />)}
{subtype === "episode" && series && <meta property="video:series" content={series} />}
