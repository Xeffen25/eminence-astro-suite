---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/open-graph-image}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/open-graph-image.mdx}
 * ---
 * @summary Renders Open Graph image structured property meta tags.
 * @description
 * Outputs `og:image` and related structured property tags for social sharing
 * image previews. Accepts an Astro `ImageMetadata` import or a plain URL string
 * or instance. Width, height, and MIME type are inferred from imported metadata;
 * for plain paths the MIME type is inferred from the file extension.
 *
 * @example
 * <OpenGraphImage src="/image.png" width={1200} height={630} alt="Banner" />
 * @example
 * <OpenGraphImage src={importedImage} alt="Banner" />
 *
 * @see {@link https://ogp.me/#structured Open Graph structured properties}
 */

import type { ImageMetadata } from "astro";

import { toHref } from "../../utils";

type ImageSource = ImageMetadata | StringOrURL;

function isMetadata(src: ImageSource): src is ImageMetadata {
	return typeof src === "object" && !(src instanceof URL) && "format" in src;
}

const IMAGE_MIME_MAP: Record<string, string> = {
	png: "image/png",
	jpg: "image/jpeg",
	jpeg: "image/jpeg",
	gif: "image/gif",
	webp: "image/webp",
	avif: "image/avif",
	svg: "image/svg+xml",
};

function inferImageMimeType(src: string, format?: string): string | undefined {
	const key = (format ?? src.split(".").pop()?.split("?")[0] ?? "").toLowerCase();
	return IMAGE_MIME_MAP[key];
}

interface Props {
	/**
	 * Supports imported Astro `ImageMetadata` or a URL/path-like value.
	 */
	src: ImageSource;
	/**
	 * HTTPS variant of `src`, emitted as `og:image:secure_url`.
	 */
	secureUrl?: StringOrURL;
	/**
	 * Overrides imported metadata width when both are provided.
	 */
	width?: number;
	/**
	 * Overrides imported metadata height when both are provided.
	 */
	height?: number;
	alt?: string;
	/**
	 * Overrides extension/metadata-based MIME inference.
	 */
	type?: string;
}

const { src, secureUrl, alt, type } = Astro.props;

const metadata = isMetadata(src) ? src : undefined;
const resolvedSrc = metadata ? metadata.src : toHref(src as StringOrURL);
const resolvedWidth = Astro.props.width ?? metadata?.width;
const resolvedHeight = Astro.props.height ?? metadata?.height;
const resolvedType = type ?? inferImageMimeType(resolvedSrc, metadata?.format);
const resolvedSecureUrl = secureUrl ? toHref(secureUrl) : undefined;
---

<meta property="og:image" content={resolvedSrc} />
{resolvedSecureUrl && <meta property="og:image:secure_url" content={resolvedSecureUrl} />}
{resolvedType && <meta property="og:image:type" content={resolvedType} />}
{resolvedWidth !== undefined && <meta property="og:image:width" content={String(resolvedWidth)} />}
{resolvedHeight !== undefined && <meta property="og:image:height" content={String(resolvedHeight)} />}
{alt && <meta property="og:image:alt" content={alt} />}
