---
import clientHeadConfig from "virtual:eminence-astro-suite/config";

import { hasAnyProp } from "../utils";

interface Content {
	content: string;
	id?: never;
	argument?: never;
}

interface IdArgument {
	content?: never;
	id: string;
	argument?: string;
}

type Props =
	| Content
	| IdArgument
	| {
			content?: never;
			id?: never;
			argument?: never;
	  };

const { id, argument, content } = (
	hasAnyProp(Astro.props) ? Astro.props : (clientHeadConfig.appleItunesApp ?? {})
) as Props;
---

{content && <meta name="apple-itunes-app" content={content} />}

{
	id && (
		<meta
			name="apple-itunes-app"
			content={[`app-id=${id}`, argument && `app-argument=${argument}`].filter(Boolean).join(", ")}
		/>
	)
}
