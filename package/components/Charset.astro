---
import config from "virtual:eminence-astro-suite/config";

import { hasAnyProp } from "../utils";

interface Props {
	/**
	 * Character encoding used in the rendered meta tag.
	 * @default "utf-8"
	 */
	charset?: string;
}

const { charset = "utf-8" } = (hasAnyProp(Astro.props) ? Astro.props : (config.charset ?? {})) as Props;
---

<meta charset={charset} />
