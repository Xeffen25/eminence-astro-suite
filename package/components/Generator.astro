---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/generator}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/generator.mdx}
 * ---
 * @summary Renders a `<meta name="generator">` tag from `Astro.generator`.
 * @description
 * Uses Astro's built-in generator value when `generate` is enabled. Set
 * `generate` to `false` to disable output.
 *
 * @example
 * <Generator />
 * @example
 * <Generator generate={false} />
 *
 * @see {@link https://docs.astro.build/en/reference/api-reference/#astrogenerator Astro.generator reference}
 * @see {@link https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/meta/name/generator MDN generator reference}
 */

import clientHeadConfig from "virtual:eminence-astro-seo/config";

interface Props {
	/**
	 * Enables generator meta tag rendering.
	 * @default true
	 */
	generate?: boolean;
}

const generate = Astro.props.generate ?? clientHeadConfig.generator ?? true;
---

{generate && <meta name="generator" content={Astro.generator} />}
