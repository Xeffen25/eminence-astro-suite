---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/humans-txt}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/humans-txt.mdx}
 * ---
 * @summary Renders a `<link rel="author">` tag pointing to `/humans.txt`.
 * @description
 * Uses the provided `href` value directly when present. If omitted, it tries
 * to generate a URL from `Astro.site` by appending `/humans.txt`. If neither
 * source is available, the component renders nothing.
 *
 * @example
 * <HumansTxt href="https://example.com/humans.txt" />
 * @example
 * <HumansTxt href={new URL("https://example.com/humans.txt")} />
 * @example
 * // Derives href from Astro.site by appending /humans.txt
 * <HumansTxt />
 * @see {@link https://humanstxt.org/ The Humans.txt Standard}
 */

import clientHeadConfig from "virtual:eminence-astro-suite/config";

interface Props {
	/**
	 * Absolute humans.txt URL rendered directly as the link href.
	 * @default `${Astro.site}/humans.txt`
	 * @example "https://example.com/humans.txt"
	 */
	href?: StringOrURL | boolean;
}

const { href: propHref } = Astro.props;
const configHref = clientHeadConfig.humansTxt;
const hrefValue = propHref !== undefined ? propHref : configHref;

const href =
	hrefValue === false
		? undefined
		: hrefValue === undefined || hrefValue === true
			? Astro.site !== undefined
				? new URL("/humans.txt", Astro.site)
				: undefined
			: hrefValue;
---

{href && <link type="text/plain" rel="author" href={href} />}
