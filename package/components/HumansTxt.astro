---
import clientHeadConfig from "virtual:eminence-astro-suite/config";

interface Props {
	/**
	 * Absolute humans.txt URL rendered directly as the link href.
	 * @default `${Astro.site}/humans.txt`
	 * @example "https://example.com/humans.txt"
	 */
	href?: string | URL | false;
}

const { href: propHref } = Astro.props;
const configHref = clientHeadConfig.humansTxt;
const hrefValue = propHref !== undefined ? propHref : configHref;

const href =
	hrefValue === false
		? undefined
		: hrefValue === undefined || hrefValue === true
			? Astro.site !== undefined
				? new URL("/humans.txt", Astro.site)
				: undefined
			: hrefValue;
---

{href && <link type="text/plain" rel="author" href={href} />}
