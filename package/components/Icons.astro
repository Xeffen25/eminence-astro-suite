---
import { dedupeIconTags, type IconTag } from "../integration/generate-icons";
import config from "virtual:eminence-astro-suite/head-tags";

interface Props {
	/**
	 * Late-bound `<link>` tag overrides.
	 * When provided, this fully replaces the build-time resolved icon tags from the virtual module.
	 */
	icons?: IconTag[];
}

const { icons = config.icons ?? [] } = Astro.props;

const iconTagsToRender = dedupeIconTags(icons);

const resolveMedia = (media: IconTag["media"]): string | undefined => {
	if (media === undefined) {
		return undefined;
	}

	if (media === "light" || media === "dark") {
		return `(prefers-color-scheme: ${media})`;
	}

	return media;
};
---

{iconTagsToRender.map(({ media, ...iconTag }) => <link {...iconTag} media={resolveMedia(media)} />)}
