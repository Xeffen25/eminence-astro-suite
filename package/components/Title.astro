---
/**
 * [ 🌐 Website ] {@link https://todo.dev/components/title}
 * [ 📝 Edit Docs ] {@link https://todo.dev/Xeffen25/eminence-astro-suite/src/content/components/title.mdx}
 * ---
 * @summary Renders a `<title>` tag with optional template formatting.
 * @description
 * Outputs the document `<title>` tag using the provided `value`. An optional
 * `template` prop containing a `%s` placeholder is replaced with `value` at
 * render time, enabling site-wide suffix or prefix patterns.
 *
 * @example
 * <Title value="Home" template="%s | My Site" />
 * @example
 * <Title value="Home" />
 *
 * @see {@link https://developer.mozilla.org/en-US/docs/Web/HTML/Element/title MDN title element reference}
 */

type TitleTemplate = `${string}%s${string}`;

interface Props {
	/**
	 * The page-specific title text.
	 */
	value: string;
	/**
	 * Optional template string containing `%s` as a placeholder for the value.
	 * @default "%s"
	 * @example "%s | My Site"
	 */
	template?: TitleTemplate;
}

const { value, template = "%s" } = Astro.props;
---

<title>{template.replace("%s", value)}</title>
